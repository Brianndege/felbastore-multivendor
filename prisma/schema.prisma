// ----------------------
// Datasource & Generator
// ----------------------
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

enum PaymentMethodKind {
  PAY_ON_DELIVERY
  CARD
  MPESA
  BANK_TRANSFER
  WALLET
}

enum ApprovalStatus {
  pending_admin
  approved
  rejected
}

enum CoverageMode {
  radius
  polygon
}

enum ProductType {
  vendor
  affiliate
}

enum ProductWorkflowStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum AffiliateNetwork {
  AMAZON_ASSOCIATES
  CJ_AFFILIATE
  SHAREASALE
  RAKUTEN_ADVERTISING
  IMPACT
  AWIN
  SHOPIFY
  EBAY_PARTNER_NETWORK
  WALMART_AFFILIATE
  ALIEXPRESS_PORTALS
  ETSY_AFFILIATE
  ENVATO
  CLICKBANK
}

// ----------------------
// Auth & Tokens
// ----------------------
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  tokenHash String?
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  vendor    Vendor?  @relation(fields: [vendorId], references: [id])
  vendorId  String?
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  tokenHash String?
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  vendor    Vendor?  @relation(fields: [vendorId], references: [id])
  vendorId  String?
}

// ----------------------
// Users
// ----------------------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  role          String    @default("user")
  mustChangePassword Boolean @default(false)
  emailVerified DateTime?
  image         String?
  phone         String?
  address       String?
  city          String?
  country       String?
  zipCode       String?
  dateOfBirth   DateTime?
  gender        String?
  preferences   String?   @db.Text
  lastLoginAt   DateTime?
  isActive      Boolean   @default(true)
  sessionVersion Int      @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  resetTokens       PasswordResetToken[]
  verificationTokens EmailVerificationToken[]
  cartItems         CartItem[]
  orders            Order[]
  reviews           Review[]
  wishlistItems     WishlistItem[]
  addresses         SavedAddress[]
  notifications     Notification[]
  analytics         UserAnalytics[]
  otpChallenges     EmailOtpChallenge[]
}

// ----------------------
// Vendors
// ----------------------
model Vendor {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String?
  storeName     String
  role          String   @default("vendor")
  emailVerified DateTime?
  image         String?
  phone         String?
  address       String?
  city          String?
  country       String?
  zipCode       String?
  description   String?  @db.Text
  businessType  String?
  taxId         String?
  website       String?
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  sessionVersion Int     @default(0)
  commissionRate Decimal @default(10.0) @db.Decimal(5, 2)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  resetTokens       PasswordResetToken[]
  verificationTokens EmailVerificationToken[]
  products          Product[]
  orderItems        OrderItem[]
  notifications     Notification[]
  analytics         VendorAnalytics[]
  inventoryAlerts   InventoryAlert[]
  deliveryZones     VendorDeliveryZone[]
  paymentMethods    VendorPaymentMethod[]
  otpChallenges     EmailOtpChallenge[]
}

// ----------------------
// Accounts & Sessions
// ----------------------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ----------------------
// Products
// ----------------------
model Product {
  id             String   @id @default(cuid())
  vendorId       String
  productType    ProductType @default(vendor)
  workflowStatus ProductWorkflowStatus @default(DRAFT)
  name           String
  description    String   @db.Text
  price          Decimal  @db.Decimal(10, 2)
  comparePrice   Decimal? @db.Decimal(10, 2)
  currency       String   @default("USD")
  category       String
  subcategory    String?
  tags           String[]
  images         String[]
  inventory      Int      @default(0)
  lowStockThreshold Int   @default(10)
  sku            String?  @unique
  weight         Decimal? @db.Decimal(8, 2)
  dimensions     String?  // JSON {length, width, height}
  status         String   @default("active")
  featured       Boolean  @default(false)
  isApproved     Boolean  @default(false)
  isDummy        Boolean  @default(false)
  createdBy      String?
  viewCount      Int      @default(0)
  soldCount      Int      @default(0)
  avgRating      Decimal? @db.Decimal(3, 2)
  reviewCount    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vendor        Vendor       @relation(fields: [vendorId], references: [id])
  cartItems     CartItem[]
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  inventoryAlerts InventoryAlert[]
  paymentMethods ProductPaymentMethod[]
  variants      ProductVariant[]
  inventoryRecords InventoryRecord[]
  searchIndexEntries ProductSearchIndex[]

  @@index([vendorId])
  @@index([category])
  @@index([status])
  @@index([featured])
  @@index([avgRating])
  @@index([soldCount])
}

// ----------------------
// Cart
// ----------------------
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ----------------------
// Orders
// ----------------------
model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  userId          String
  status          String   @default("pending")
  totalAmount     Decimal  @db.Decimal(10, 2)
  shippingAmount  Decimal  @db.Decimal(10, 2) @default(0)
  taxAmount       Decimal  @db.Decimal(10, 2) @default(0)
  discountAmount  Decimal  @db.Decimal(10, 2) @default(0)
  paymentStatus   String   @default("pending")
  paymentMethod   String?
  paymentIntentId String?  @unique
  shippingAddress String   @db.Text
  billingAddress  String   @db.Text
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  orderItems OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  vendorId     String
  quantity     Int
  price        Decimal @db.Decimal(10, 2)
  productName  String
  productImage String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  vendor  Vendor  @relation(fields: [vendorId], references: [id])

  @@index([orderId])
  @@index([vendorId])
}

// ----------------------
// Reviews
// ----------------------
model Review {
  id         String   @id @default(cuid())
  userId     String
  productId  String
  rating     Int
  comment    String?  @db.Text
  images     String[]
  isDummy    Boolean  @default(false)
  createdBy  String?
  isVerified Boolean  @default(false)
  helpfulCount Int    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([rating])
}

// ----------------------
// Wishlist
// ----------------------
model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

// ----------------------
// Saved Addresses
// ----------------------
model SavedAddress {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  address   String
  city      String?
  country   String?
  zipCode   String?
  isDefault Boolean   @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ----------------------
// Notifications
// ----------------------
model Notification {
  id        String   @id @default(cuid())
  userId    String?
  vendorId  String?
  type      String?  @default("general")
  priority  String?  @default("normal")
  title     String
  message   String
  data      String?  @db.Text
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  vendor Vendor? @relation(fields: [vendorId], references: [id])
}

// ----------------------
// Analytics
// ----------------------
model UserAnalytics {
  id        String   @id @default(cuid())
  userId    String
  data      String?  @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model VendorAnalytics {
  id        String   @id @default(cuid())
  vendorId  String
  data      String?  @db.Text
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])
}

model OutboxEvent {
  id           String   @id @default(cuid())
  topic        String
  entityType   String?
  entityId     String?
  payload      String   @db.Text
  status       String   @default("pending")
  attemptCount Int      @default(0)
  publishedAt  DateTime?
  lastError    String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([status, createdAt])
  @@index([topic, createdAt])
}

model EmailOtpChallenge {
  id         String   @id @default(cuid())
  challengeId String  @unique
  email      String
  userType   String
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  maxAttempts Int     @default(5)
  lockedUntil DateTime?
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  vendor    Vendor?  @relation(fields: [vendorId], references: [id])
  vendorId  String?

  @@index([email, userType, createdAt])
}

model AuthAuditLog {
  id        String   @id @default(cuid())
  event     String
  status    String
  userType  String?
  emailHash String?
  ipHash    String?
  userAgent String?
  metadata  String?  @db.Text
  createdAt DateTime @default(now())

  @@index([event, createdAt])
  @@index([status, createdAt])
}

// ----------------------
// Inventory Alerts
// ----------------------
model InventoryAlert {
  id        String   @id @default(cuid())
  vendorId  String
  productId String
  type      String?  @default("low_stock")
  threshold Int?
  currentStock Int?
  message   String
  createdAt DateTime @default(now())

  vendor  Vendor  @relation(fields: [vendorId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([vendorId])
  @@index([productId])
}

model VendorDeliveryZone {
  id             String       @id @default(cuid())
  vendorId       String
  name           String
  mode           CoverageMode @default(radius)
  centerLat      Decimal?     @db.Decimal(10, 7)
  centerLng      Decimal?     @db.Decimal(10, 7)
  radiusKm       Decimal?     @db.Decimal(8, 2)
  polygonGeoJson String?      @db.Text
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, isActive])
}

model VendorPaymentMethod {
  id               String            @id @default(cuid())
  vendorId         String
  methodKind       PaymentMethodKind
  label            String
  config           String?           @db.Text
  approvalStatus   ApprovalStatus    @default(pending_admin)
  approvedByUserId String?
  approvedAt       DateTime?
  rejectionReason  String?           @db.Text
  isActive         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  vendor   Vendor                  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  products ProductPaymentMethod[]

  @@index([vendorId, approvalStatus, isActive])
}

model ProductPaymentMethod {
  id                    String   @id @default(cuid())
  productId             String
  vendorPaymentMethodId String
  createdAt             DateTime @default(now())

  product             Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendorPaymentMethod VendorPaymentMethod @relation(fields: [vendorPaymentMethodId], references: [id], onDelete: Cascade)

  @@unique([productId, vendorPaymentMethodId])
  @@index([productId])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  sku       String?
  title     String
  options   String?  @db.Text
  price     Decimal? @db.Decimal(10, 2)
  inventory Int      @default(0)
  isDummy   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model InventoryRecord {
  id          String   @id @default(cuid())
  productId   String
  quantity    Int
  source      String?
  note        String?
  isDummy     Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
}

model ProductSearchIndex {
  id          String   @id @default(cuid())
  productId   String
  searchable  String   @db.Text
  category    String?
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId])
  @@index([category])
}

model AffiliateProduct {
  id                String           @id @default(cuid())
  externalProductId String
  title             String
  description       String           @db.Text
  externalUrl       String
  affiliateNetwork  AffiliateNetwork
  commissionRate    Decimal          @db.Decimal(5, 2)
  imageUrl          String
  price             Decimal          @db.Decimal(10, 2)
  currency          String           @default("USD")
  category          String
  subcategory       String?
  isSynced          Boolean          @default(false)
  isActive          Boolean          @default(true)
  featuredScore     Int              @default(0)
  clickCount        Int              @default(0)
  lastSyncedAt      DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  clicks AffiliateClick[]
  conversions AffiliateConversion[]

  @@unique([affiliateNetwork, externalProductId])
  @@index([isActive, category])
  @@index([featuredScore])
}

model AffiliateClick {
  id                 String   @id @default(cuid())
  affiliateProductId String
  clickToken         String   @unique
  ipHash             String?
  userAgent          String?
  referrer           String?
  userId             String?
  createdAt          DateTime @default(now())

  affiliateProduct AffiliateProduct @relation(fields: [affiliateProductId], references: [id], onDelete: Cascade)

  @@index([affiliateProductId, createdAt])
}

model AffiliateConversion {
  id                 String   @id @default(cuid())
  affiliateProductId String
  clickToken         String?
  externalOrderId    String?
  amount             Decimal? @db.Decimal(10, 2)
  currency           String?  @default("USD")
  status             String   @default("pending")
  network            AffiliateNetwork
  metadata           String?  @db.Text
  convertedAt        DateTime?
  createdAt          DateTime @default(now())

  affiliateProduct AffiliateProduct @relation(fields: [affiliateProductId], references: [id], onDelete: Cascade)

  @@index([affiliateProductId, createdAt])
  @@index([network, status])
}

model AffiliateSyncRun {
  id             String    @id @default(cuid())
  network        AffiliateNetwork
  mode           String
  status         String
  importedCount  Int       @default(0)
  updatedCount   Int       @default(0)
  failedCount    Int       @default(0)
  error          String?   @db.Text
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  @@index([network, startedAt])
}

model AdminCleanupRun {
  id                String   @id @default(cuid())
  adminUserId       String
  adminEmail        String
  dryRun            Boolean  @default(true)
  criteria          String?  @db.Text
  removedProductIds String[]
  removedCount      Int      @default(0)
  startedAt         DateTime @default(now())
  completedAt       DateTime?

  backups AdminCleanupBackup[]

  @@index([adminUserId, startedAt])
}

model AdminCleanupBackup {
  id           String   @id @default(cuid())
  runId        String
  tableName    String
  recordId     String
  payload      String   @db.Text
  createdAt    DateTime @default(now())

  run AdminCleanupRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, tableName])
}
